# ============================================================
#  spam-digest — environment variables example
#  Copy to .env and fill in your values.
#  Do NOT commit your real .env file to version control.
# ============================================================

# --- IMAP (single mailbox mode) ---
# Use MAILBOX_CONFIGS (below) for multiple mailboxes instead.
IMAP_SERVER=imap.example.com
IMAP_PORT=993
EMAIL_USER=you@example.com
EMAIL_PASS=your-imap-password
EMAIL_ADDRESS=you@example.com   # display label (optional, defaults to EMAIL_USER)
SPAM_FOLDER=Junk                # common values: Junk, Spam, INBOX.Spam, [Gmail]/Spam
MAX_EMAILS=100                  # max emails to include per mailbox per run

# --- IMAP (multi-mailbox mode) ---
# When set, this takes priority over the single-mailbox vars above.
# MAILBOX_CONFIGS=[
#   {"imap_server":"imap.example.com","imap_port":993,"email_user":"a@example.com","email_pass":"secret","spam_folder":"Junk","max_emails":100},
#   {"imap_server":"imap.other.com","email_user":"b@other.com","email_pass":"secret2"}
# ]

# --- SMTP (digest email) ---
SMTP_HOST=smtp.example.com
SMTP_PORT=587                   # 587 = STARTTLS, 465 = SSL
SMTP_USER=you@example.com
SMTP_PASS=your-smtp-password
# DIGEST_TO=other@example.com        # optional: override digest recipient (single-mailbox only; defaults to EMAIL_USER)
DIGEST_FROM=spam-digest@example.com  # optional sender address (defaults to SMTP_USER)

# Send the digest even when no spam emails are found (default: false = skip)
SEND_IF_EMPTY=false

# --- AI Classification (Anthropic Claude) ---
# Set AI_PROVIDER=anthropic to enable, or leave as 'none' to disable.
AI_PROVIDER=none
AI_API_KEY=sk-ant-...
AI_MODEL=claude-haiku-4-5-20251001   # Haiku recommended: fast and very cheap
AI_MAX_EMAILS=50                     # cost control: max emails sent to AI per run

# --- Schedule (cron) ---
# Default: every day at 08:00
SCHEDULE_MIN=0
SCHEDULE_HOUR=8
SCHEDULE_DAY=*    # * = every day; 0=Sunday, 1=Monday ... 6=Saturday

# Run the digest immediately when the container starts (default: false).
# Set to true only if you want an extra run at startup in addition to the cron schedule.
RUN_ON_START=false

# --- Web dashboard ---
WEB_PORT=8080

# --- Timezone ---
TZ=Europe/Rome
